<StackPanel Margin="0,-10,0,0" 
xmlns:sys="clr-namespace:System;assembly=mscorlib" 
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:local="clr-namespace:PCL;assembly=Plain Craft Launcher 2">
<StackPanel.Triggers>
</StackPanel.Triggers>
<StackPanel.Resources>
<Style TargetType="ListItem"><Setter Property="Foreground" Value="{DynamicResource ColorBrush1}"/><Setter Property="Margin" Value="0,4"/></Style>
<Style TargetType="List"><Setter Property="Foreground" Value="{DynamicResource ColorBrush3}"/><Setter Property="Margin" Value="20,6,0,6"/><Setter Property="MarkerStyle" Value="1"/><Setter Property="Padding" Value="0"/></Style>
<Style TargetType="Paragraph"><Setter Property="LineHeight" Value="12"/><Setter Property="TextIndent" Value="0"/><Setter Property="Margin" Value="0,8"/></Style>
<Style TargetType="TextBlock"><Setter Property="TextWrapping" Value="Wrap"/><Setter Property="HorizontalAlignment" Value="Left"/><Setter Property="FontSize" Value="14"/><Setter Property="Foreground" Value="{DynamicResource ColorBrush1}"/></Style>
<Style TargetType="FlowDocument"><Setter Property="FontFamily" Value="Microsoft YaHei UI"/><Setter Property="FontSize" Value="14"/><Setter Property="TextAlignment" Value="Left"/><Setter Property="Foreground" Value="{DynamicResource ColorBrush1}"/></Style>
<Style TargetType="FlowDocumentScrollViewer"><Setter Property="IsSelectionEnabled" Value="False"/><Setter Property="VerticalScrollBarVisibility" Value="Hidden"/><Setter Property="Margin" Value="0"/></Style>
<Style x:Key="H2" TargetType="Paragraph"><Setter Property="FontSize" Value="22"/><Setter Property="Margin" Value="0,10,0,5"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="{DynamicResource ColorBrush3}"/></Style>
<Style x:Key="H5" TargetType="Paragraph"><Setter Property="FontSize" Value="14"/><Setter Property="Margin" Value="0,8,0,1"/><Setter Property="Foreground" Value="{DynamicResource ColorBrush4}"/></Style>
<Style  TargetType="TextBox" x:Key="BlockCode">
    <Setter Property="Foreground" Value="{DynamicResource ColorBrush1}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="IsReadOnly" Value="True" />
    <Setter Property="FontFamily" Value="Consolas" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="TextBox">
                <Border Background="{DynamicResource ColorBrush7}" Opacity="0.8" BorderBrush="{DynamicResource ColorBrush4}" BorderThickness="0" CornerRadius="0,0,5,5" Padding="16,8,16,12"> 
                    <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" />
                </Border>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>
<Style x:Key="Card" TargetType="local:MyCard"><Setter Property="Margin" Value="0,5"/></Style>
<Style x:Key="Hr" TargetType="Section"><Setter Property="Margin" Value="0,4,0,0"/><Setter Property="BorderThickness" Value="0,1.5,0,0"/><Setter Property="BorderBrush" Value="{StaticResource ColorBrush4}"/><Setter Property="FontSize" Value="4"/></Style>
<Style x:Key="Quote" TargetType="Section"><Setter Property="BorderThickness" Value="5,0,0,0"/><Setter Property="BorderBrush" Value="{DynamicResource ColorBrush4}"/><Setter Property="Padding" Value="10,0"/><Setter Property="Margin" Value="0,12"/></Style>
<Style x:Key="typedQuote" BasedOn="{StaticResource Quote}" TargetType="Section"><Setter Property="Padding" Value="10,2"/></Style>
<Style x:Key="translatornoteQuote" BasedOn="{StaticResource typedQuote}" TargetType="Section"><Setter Property="BorderBrush" Value="{StaticResource ColorBrush4}"/><Setter Property="Background" Value="{StaticResource ColorBrush6}"/></Style>
<Style x:Key="H3" TargetType="Paragraph"><Setter Property="FontSize" Value="18"/><Setter Property="Margin" Value="0,10,0,3"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="{DynamicResource ColorBrush4}"/></Style>
<Style x:Key="Lp" TargetType="Paragraph"><Setter Property="LineHeight" Value="16"/><Setter Property="TextIndent" Value="0"/></Style>
<Style x:Key="ContentStack" TargetType="StackPanel"><Setter Property="Margin" Value="20,40,20,20"/></Style>
<Style x:Key="H4" TargetType="Paragraph"><Setter Property="FontSize" Value="16"/><Setter Property="Margin" Value="0,10,0,1"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="{DynamicResource ColorBrush4}"/></Style>
<Style x:Key="devnoteQuote" BasedOn="{StaticResource typedQuote}" TargetType="Section"><Setter Property="BorderBrush" Value="{StaticResource ColorBrush4}"/><Setter Property="Background" Value="{StaticResource ColorBrush6}"/></Style>
<Style  TargetType="TextBox" x:Key="InlineCode">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="IsReadOnly" Value="True" />
    <Setter Property="Margin" Value="2,0,2,-4" />
    <Setter Property="FontFamily" Value="Consolas" />
    <Setter Property="Foreground" Value="{DynamicResource ColorBrush1}" />
    <Setter Property="Height" Value="18" />
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="TextBox">
                <Border Background="{DynamicResource ColorBrush6}" Opacity="0.9" BorderBrush="{DynamicResource ColorBrush4}" BorderThickness="0" CornerRadius="5" Padding="4,0.2"> 
                    <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" />
                </Border>
                <ControlTemplate.Triggers>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>
<Style x:Key="BlockCodeBorder" TargetType="Border"><Setter Property="Background" Value="{DynamicResource ColorBrush4}"/><Setter Property="Opacity" Value="0.8"/><Setter Property="CornerRadius" Value="5"/><Setter Property="Margin" Value="2"/></Style>

</StackPanel.Resources>
<local:MyCard Title="最新发布候选版 - 26.1.1-rc-1" CanSwap="True" IsSwaped="false" Style="{StaticResource Card}" >
<StackPanel Style="{StaticResource ContentStack}">
<FlowDocumentScrollViewer >
<FlowDocument>

</FlowDocument>
</FlowDocumentScrollViewer><local:MyLoading Margin="0,8" Text="翻译施工中"/>
</StackPanel>
</local:MyCard><local:MyCard Title="最新正式版 - 26.1" CanSwap="True" IsSwaped="True" Style="{StaticResource Card}" >
<StackPanel Style="{StaticResource ContentStack}">
<FlowDocumentScrollViewer >
<FlowDocument>
<Paragraph Style="{StaticResource H3}">史上最萌的一次更新现已到来！</Paragraph><Paragraph>无论你准备与否，小鬼当家更新已经来了！全新版本的幼年生物席卷了整个 Minecraft，在各个生物群系和建筑中掀起一股可爱风暴。竖起耳朵倾听萌翻天的新音效，为你的宠物合成命名牌，用金蒲公英让小宝宝们永远保持幼年模样。孩子们已经正式出笼——准备好去收集、爱抚，并让这些小捣蛋鬼在你的世界里制造一点混乱吧！</Paragraph><Paragraph Style="{StaticResource H2}">新特性</Paragraph><List>
<ListItem><Paragraph Style="{StaticResource Lp}">为狼、猫、猪、马和鸡增加了新的幼年音效</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">增加了金蒲公英</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">增加了下列动物音效的成年音效变体：</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">猫现在有了新的变体 <TextBox Style="{StaticResource InlineCode}">royal</TextBox></Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">猪现在有了新的变体 <TextBox Style="{StaticResource InlineCode}">mini</TextBox> 和 <TextBox Style="{StaticResource InlineCode}">big</TextBox></Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">牛现在有了新的变体 <TextBox Style="{StaticResource InlineCode}">moody</TextBox></Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">鸡现在有了新的变体 <TextBox Style="{StaticResource InlineCode}">picky</TextBox></Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">所有生物原来使用的音效现在命名为 <TextBox Style="{StaticResource InlineCode}">classic</TextBox></Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">上列所有动物其音效变体现在会随机分配新的变体或原始版本</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">增加了当音符盒放在铜块上，音符盒音色为小号</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">音色因铜块的氧化等级不同而不同</Paragraph></ListItem>
</List><Paragraph Style="{StaticResource H3}">金蒲公英</Paragraph><List>
<ListItem><Paragraph Style="{StaticResource Lp}">金蒲公英是一种新的类型的花，可以用于阻止生物成长</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">对幼年生物使用金蒲公英可以使其停止成长</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">对已经停止成长的幼年生物使用金蒲公英可以使其继续成长</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">金蒲公英不能被用于敌对幼年生物以及村民</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">可以使用蒲公英和金粒合成</Paragraph></ListItem>
</List><Paragraph Style="{StaticResource H2}">更改</Paragraph><List>
<ListItem><Paragraph Style="{StaticResource Lp}">重制了更多幼年生物的外观</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">命名牌现在可以合成了，由一张纸和任意一个金属粒合成</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">从远古城市和林地府邸中移除了命名牌</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">深板岩现在可以在切石机中直接合成为其圆石、磨制、砖和瓦变种</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">石头现在可以在切石机中直接合成为其圆石变种</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">更新了主菜单的背景全景图</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">微调了默认 JVM 选项</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">用于将方块光与天空光等级映射为屏幕上实际亮度的算法已被完全重写</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">移除了小小 Herobrine</Paragraph></ListItem>
</List><Paragraph Style="{StaticResource H3}">幼年生物</Paragraph><List>
<ListItem><Paragraph Style="{StaticResource Lp}">更新了下列幼年生物的模型与纹理：</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">牛</Paragraph></ListItem>

<ListItem><Paragraph Style="{StaticResource Lp}">必须为 <TextBox Style="{StaticResource InlineCode}">[2,8]</TextBox> 的子区间</Paragraph></ListItem>
<ListItem><Paragraph Style="{StaticResource Lp}">默认：<TextBox Style="{StaticResource InlineCode}">[1,1]</TextBox>（即恰好一个物品）</Paragraph></ListItem>
